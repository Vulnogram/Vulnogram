MONGO_HOST=vulnogram-mongo
# Copy this file to .env or another private env file and replace the sample credentials
# before starting Vulnogram. Startup now refuses the shipped sample/default values.
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_MONGO_PASSWORD
MONGO_INITDB_ROOT_USERNAME=changeMeMongoUser
MONGO_PORT=27017
# Optional full MongoDB connection URI override.
# When set, this takes precedence over MONGO_HOST/MONGO_PORT/MONGO_INITDB_ROOT_*.
#MONGO_URL=mongodb://changeMeMongoUser:CHANGE_ME_MONGO_PASSWORD@vulnogram-mongo:27017
START_COMMAND=node init-vulnogram.js && node app.js
VULNOGRAM_ADMIN_CNA_EMAIL=security@example.com
VULNOGRAM_ADMIN_EMAIL=user@example.com
VULNOGRAM_ADMIN_NAME=Example User
VULNOGRAM_ADMIN_PASSWORD=CHANGE_ME_VULNOGRAM_ADMIN_PASSWORD
VULNOGRAM_ADMIN_USERNAME=changeMeAdmin
VULNOGRAM_HOST=0.0.0.0
VULNOGRAM_PORT=3555
